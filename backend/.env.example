# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=store_db
DB_USER=store_app
DB_PASSWORD=store_app_pass

# --- JWT ---
# CHANGE THIS: openssl rand -hex 32
SECRET_KEY=change-me-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS (comma-separated, no spaces, no trailing slashes) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- App ---
ENV=development
LOG_LEVEL=INFO
